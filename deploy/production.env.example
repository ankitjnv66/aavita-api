SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=9090

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://127.0.0.1:5432/AavitaDB
SPRING_DATASOURCE_USERNAME=CHANGE_ME
SPRING_DATASOURCE_PASSWORD=CHANGE_ME

# JWT and OAuth
JWT_KEY=CHANGE_ME_BASE64_256_BIT_KEY
GOOGLE_SMARTHOME_CLIENT_ID=smarthome-client-001
GOOGLE_SMARTHOME_CLIENT_SECRET=CHANGE_ME
GOOGLE_SMARTHOME_AGENT_USER_ID=user-001

# Alexa
ALEXA_SHARED_SECRET=CHANGE_ME

# MQTT TLS
MQTT_ENABLED=true
MQTT_BROKER=ssl://127.0.0.1:8883
MQTT_CLIENT_ID=JavaClient
MQTT_SUBSCRIBE_TOPIC=+/+/sub
MQTT_TLS_TRUSTSTORE=file:/opt/aavita/certs/aavita-truststore.jks
MQTT_TLS_TRUSTSTORE_PASSWORD=CHANGE_ME

# Google HomeGraph service account key on server
GOOGLE_HOMEGRAPH_SERVICE_ACCOUNT_KEY=file:/opt/aavita/certs/homegraph-service-account.json
